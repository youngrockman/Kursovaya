<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Vosmerka.Models"
        x:CompileBindings="False"
        mc:Ignorable="d" 
        d:DesignWidth="800" 
        d:DesignHeight="600"
        Icon="C:\Users\IVAN\RiderProjects\Vosmerka\Vosmerka\bin\Debug\net9.0\vosmerka.ico"
        x:Class="Vosmerka.MainWindow"
        Title="Каталог продукции">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Row="0" Margin="0 0 0 20" Spacing="10">
            <TextBox x:Name="SearchBox" Watermark="Введите для поиска..." 
                     Width="400" HorizontalAlignment="Left"/>
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ComboBox x:Name="FilterBox" Width="200"
                          SelectedIndex="0"/>
                <ComboBox x:Name="SortBox" Width="200"
                          SelectedIndex="0"/>
                <ComboBox x:Name="SortOrderBox" Width="200"
                          SelectedIndex="0"/>
            </StackPanel>
        </StackPanel>

        
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="ProductListBox" Margin="0 10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" 
                                  Margin="0 10"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15" Margin="0 5" 
                              BorderBrush="#CCCCCC" BorderThickness="1"
                              CornerRadius="5"
                              Background="White"
                              HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>

                                
                                <Image Source="{Binding ProductImage}" 
                                     Grid.Column="0"
                                     Width="80" Height="80"
                                     Stretch="Uniform"
                                     Margin="5"/>
                                
                                <TextBlock Text="{Binding Title}" 
                                         Grid.Column="1"
                                         VerticalAlignment="Center"
                                         Margin="10 0"
                                         FontWeight="SemiBold"/>

                                
                                <Border Grid.Column="2" 
                                      BorderThickness="1"
                                      CornerRadius="3"
                                      Padding="5"
                                      VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ArticleNumber}"
                                             HorizontalAlignment="Center"
                                             FontFamily="Consolas"/>
                                </Border>

                               
                                <TextBlock Text="{Binding MaterialsList}" 
                                         Grid.Column="3"
                                         VerticalAlignment="Center"
                                         Margin="10 0"
                                         TextWrapping="Wrap"
                                         MaxWidth="300"/>

                                
                                <TextBlock Text="{Binding CalculatedCost, StringFormat='{}{0:N2} ₽'}"
                                           Grid.Column="4"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="10 0 20 0"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           MinWidth="160"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        
        <StackPanel Grid.Row="2" 
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0 10"
                  Spacing="5">
            <Button Content="←" Click="PrevPage_Click" 
                    Width="35" FontWeight="Bold"
                    Background="Transparent" BorderThickness="0"/>
            
            <ItemsControl x:Name="PaginationPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            
            <Button Content="→" Click="NextPage_Click" 
                    Width="35" FontWeight="Bold"
                    Background="Transparent" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>